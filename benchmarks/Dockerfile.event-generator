# Dockerfile for building the event generator tool

FROM gcc:14 AS builder

WORKDIR /build
COPY src/event-generator.c .
RUN gcc -O2 -o event-generator event-generator.c -lpthread

FROM debian:bookworm-slim

COPY --from=builder /build/event-generator /usr/local/bin/

ENTRYPOINT ["/usr/local/bin/event-generator"]
CMD ["--help"]
