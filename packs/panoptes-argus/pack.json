{
  "addonType": "security",
  "cloudTypes": ["all"],
  "displayName": "Panoptes Argus - File Integrity Monitoring",
  "charts": ["charts/panoptes-argus"],
  "layer": "addon",
  "name": "panoptes-argus",
  "version": "2.0.0",
  "eol": "2028-01-01",
  "group": "LTS",
  "constraints": {
    "dependencies": [
      {
        "packName": "kubernetes",
        "layer": "k8s",
        "minVersion": "1.28.0",
        "type": "required"
      }
    ],
    "resources": [
      {
        "type": "cpu",
        "minLimit": 250,
        "components": [
          {
            "scheduleType": "all",
            "resourceRequestParamName": "daemon.resources.requests.cpu"
          }
        ]
      }
    ]
  },
  "annotations": {
    "category": "Security",
    "subcategory": "File Integrity Monitoring",
    "description": "Real-time file integrity monitoring for Kubernetes using inotify",
    "supportedOS": "linux",
    "supportedArchitectures": "amd64,arm64"
  }
}
