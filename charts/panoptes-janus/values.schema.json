{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Panoptes Janus Values",
  "description": "Configuration for the Panoptes Janus File Access Auditing Helm chart",
  "type": "object",
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name"
    },
    "global": {
      "type": "object",
      "description": "Global configuration shared across components",
      "properties": {
        "cluster": {
          "type": "object",
          "description": "Cluster identification for multi-cluster deployments",
          "properties": {
            "name": {
              "type": "string",
              "description": "Cluster name used in event labels and multi-cluster correlation"
            },
            "environment": {
              "type": "string",
              "description": "Environment name (e.g., production, staging, dev)"
            },
            "region": {
              "type": "string",
              "description": "Cloud region or datacenter identifier"
            }
          }
        }
      }
    },
    "controller": {
      "type": "object",
      "description": "Janus operator (controller-manager) configuration",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "description": "Container image repository for the janus controller"
            },
            "tag": {
              "type": "string",
              "description": "Container image tag"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["IfNotPresent", "Always", "Never"],
              "description": "Image pull policy"
            }
          }
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Number of controller replicas. Only one is active (leader election), others are standby for HA."
        },
        "resources": {
          "$ref": "#/definitions/resources",
          "description": "CPU and memory resource requests and limits for the controller"
        },
        "nodeSelector": {
          "type": "object",
          "description": "Node selector for controller pod scheduling",
          "additionalProperties": { "type": "string" }
        },
        "tolerations": {
          "type": "array",
          "description": "Tolerations for controller pod scheduling",
          "items": { "$ref": "#/definitions/toleration" }
        },
        "affinity": {
          "type": "object",
          "description": "Affinity rules for controller pod scheduling"
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "description": "Create a dedicated ServiceAccount for the controller"
            },
            "name": {
              "type": "string",
              "description": "Name of the ServiceAccount. If empty and create is true, uses the release fullname."
            },
            "annotations": {
              "type": "object",
              "description": "Annotations to add to the ServiceAccount (e.g., for IAM role binding)",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "priorityClassName": {
          "type": "string",
          "description": "PriorityClass name for the controller pods"
        }
      }
    },
    "daemon": {
      "type": "object",
      "description": "janusd DaemonSet configuration. Runs on every node to audit file access via fanotify.",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "description": "Container image repository for janusd"
            },
            "tag": {
              "type": "string",
              "description": "Container image tag"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["IfNotPresent", "Always", "Never"],
              "description": "Image pull policy"
            }
          }
        },
        "resources": {
          "$ref": "#/definitions/resources",
          "description": "CPU and memory resource requests and limits for janusd"
        },
        "nodeSelector": {
          "type": "object",
          "description": "Node selector for daemon pod scheduling",
          "additionalProperties": { "type": "string" }
        },
        "tolerations": {
          "type": "array",
          "description": "Tolerations for daemon pod scheduling. Defaults to tolerate NoSchedule on all nodes.",
          "items": { "$ref": "#/definitions/toleration" }
        },
        "securityContext": {
          "type": "object",
          "description": "Security context for the janusd container. Requires SYS_ADMIN, SYS_PTRACE, DAC_READ_SEARCH, AUDIT_WRITE capabilities.",
          "properties": {
            "privileged": {
              "type": "boolean",
              "description": "Run as privileged container. Not recommended; use capabilities instead."
            },
            "capabilities": {
              "type": "object",
              "properties": {
                "add": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Linux capabilities to add. Must include SYS_ADMIN, SYS_PTRACE, DAC_READ_SEARCH, AUDIT_WRITE for fanotify monitoring."
                }
              }
            }
          }
        },
        "priorityClassName": {
          "type": "string",
          "description": "PriorityClass name for daemon pods. Recommended: system-node-critical for security monitoring."
        }
      }
    },
    "enforcement": {
      "type": "object",
      "description": "Global enforcement mode default",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "true = block denied access (enforcement mode), false = audit-only (log but allow all access)"
        }
      }
    },
    "audit": {
      "type": "object",
      "description": "Kernel audit integration settings",
      "properties": {
        "kernelAudit": {
          "type": "boolean",
          "description": "Write fanotify events to /var/log/audit/audit.log for SIEM integration"
        }
      }
    },
    "service": {
      "type": "object",
      "description": "gRPC service configuration for communication between controller and daemons",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "description": "Kubernetes Service type"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "gRPC listen port for janusd (default: 50052)"
        }
      }
    },
    "observability": {
      "type": "object",
      "description": "Monitoring and observability configuration",
      "properties": {
        "prometheus": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Prometheus metrics endpoint"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "description": "Metrics endpoint port (default: 8080)"
            }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a Prometheus ServiceMonitor resource. Requires the Prometheus Operator."
            },
            "interval": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$",
              "description": "Scrape interval (e.g., 30s, 1m)"
            },
            "namespace": {
              "type": "string",
              "description": "Namespace for the ServiceMonitor. If empty, uses the release namespace."
            }
          }
        }
      }
    },
    "containerRuntime": {
      "type": "object",
      "description": "Container runtime detection settings",
      "properties": {
        "detection": {
          "type": "string",
          "enum": ["auto", "containerd", "cri-o"],
          "description": "Container runtime type. 'auto' detects containerd vs CRI-O automatically."
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "description": "NetworkPolicy configuration for restricting network access",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create NetworkPolicy resources to restrict ingress/egress"
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "description": "PodDisruptionBudget configuration for the controller Deployment",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create a PodDisruptionBudget for the controller"
        },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ],
          "description": "Minimum available pods (integer or percentage)"
        }
      }
    }
  },
  "definitions": {
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string", "description": "CPU request (e.g., 100m, 0.5)" },
            "memory": { "type": "string", "description": "Memory request (e.g., 128Mi, 1Gi)" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string", "description": "CPU limit (e.g., 500m, 1)" },
            "memory": { "type": "string", "description": "Memory limit (e.g., 256Mi, 2Gi)" }
          }
        }
      }
    },
    "toleration": {
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "operator": { "type": "string", "enum": ["Exists", "Equal"] },
        "value": { "type": "string" },
        "effect": { "type": "string", "enum": ["NoSchedule", "PreferNoSchedule", "NoExecute"] },
        "tolerationSeconds": { "type": "integer" }
      }
    }
  }
}
